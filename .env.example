# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model (default: claude-sonnet-4-5-20250929)
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Voice settings
# WHISPER_MODEL: tiny | base | small | medium | large (larger = more accurate, slower)
# Model is auto-downloaded on first run to ~/.cache/whisper/
WHISPER_MODEL=base

# Wake word detection (whisper-tiny on a sliding 2s window — no training required)
# WAKE_MODEL: tiny | base (tiny recommended — fast enough for continuous listening)
WAKE_MODEL=tiny
# WAKE_PHRASE: any phrase you like — no training data needed
WAKE_PHRASE=hey computer

ENABLE_TTS=true

# Kokoro TTS voice — model auto-downloads to ~/.cache/huggingface/ on first run (~80MB)
# Requires: sudo apt install espeak-ng
# American English voices: af_heart (default), af_sky, am_adam, am_michael
# British English voices: bf_emma, bf_isabella, bm_george, bm_lewis
TTS_VOICE=af_heart

SILENCE_THRESHOLD=1000
SILENCE_DURATION=2.0
# How long to wait for follow-up speech (seconds) before ending the conversation session
CONVERSATION_IDLE_TIMEOUT=8

# Container settings
CONTAINER_MEMORY=256m

# Skill API keys (optional - skills auto-disable if key is missing)
BRAVE_API_KEY=your_brave_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here
